        "electron:build": "npm run build:preload && npm run build:main && npm run build:renderer && electron-builder"
    },
    "devDependencies": {
        "@types/electron": "^1.4.38",
        "@types/node": "^24.10.1",
        "concurrently": "^9.2.1",
        "electron": "^39.2.4",
        "jsdom": "^27.4.0",
        "typescript": "~5.9.3",
        "vite": "^7.2.4",
        "vitest": "^4.0.17",
        "wait-on": "^9.0.3"
    },
    "dependencies": {
        "lz-string": "^1.5.0"
    }
}