{
    "compilerOptions": {
        "moduleResolution": "Node",
        "outDir": "dist/main",
        "rootDir": "src",
        "lib": [
            "ES2022"
        ],
        "types": [
            "node"
        ],
        "module": "CommonJS",
        "target": "ES2022",
        "strict": true,
        "skipLibCheck": true
    },
    "include": [
        "src/main/**/*.ts",
        "src/shared/**/*.ts"
    ]
}