        "outDir": "dist/preload",
        "rootDir": "src",
        "lib": [
            "DOM",
            "ES2022"
        ],
        "types": [
            "node"
        ],
        "module": "CommonJS",
        "target": "ES2022",
        "strict": true
    },
    "include": [
        "src/preload/**/*.ts"
    ]
}